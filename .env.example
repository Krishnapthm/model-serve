# ModelServe — Environment Variables
# Copy this file: cp .env.example .env
# Then edit with your values.

# ---------- HuggingFace ----------
# Required for gated models (e.g. Llama). Optional for public models.
HF_TOKEN=hf_your_token_here

# ---------- Database ----------
POSTGRES_USER=modelserve
POSTGRES_PASSWORD=changeme
POSTGRES_DB=modelserve
DATABASE_URL=postgresql+asyncpg://modelserve:changeme@db:5432/modelserve

# ---------- Security ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string-min-32-chars

# ---------- CORS ----------
# Use * to avoid CORS errors when public frontend origins (IP/domain) change.
# For stricter setups, use comma-separated origins instead.
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
# Optional regex matcher (applied in addition to CORS_ORIGINS)
CORS_ORIGIN_REGEX=

# ---------- Frontend ----------
# Optional override for frontend API target.
# Leave empty to auto-use: <current-browser-host>:8000/api/v1
VITE_API_BASE_URL=

# ---------- vLLM Model Slots (max 4) ----------
# Set each slot to a HuggingFace model ID. Leave empty to skip.
VLLM_MODEL_1=mistralai/Mistral-7B-Instruct-v0.3
VLLM_MODEL_2=
VLLM_MODEL_3=
VLLM_MODEL_4=

# Host used by the backend to construct external endpoint URLs.
# Inside Compose, set to the public/accessible hostname of the Docker host.
VLLM_HOST=localhost

# External port for each vLLM slot (defaults: 8081–8084).
# Override if your firewall or cloud provider requires different ports.
VLLM_BASE_PORT=8081
# VLLM_PORT_1=8081
# VLLM_PORT_2=8082
# VLLM_PORT_3=8083
# VLLM_PORT_4=8084

# Optional shared API key for all vLLM instances.
# When set, clients must send: Authorization: Bearer <this-key>
VLLM_API_KEY=

# vLLM ROCm image — change tag for specific versions.
# https://hub.docker.com/r/vllm/vllm-openai-rocm/tags
VLLM_ROCM_IMAGE=vllm/vllm-openai-rocm:latest
