# ModelServe — Environment Variables
# Copy this file: cp .env.example .env
# Then edit with your values.

# ---------- HuggingFace ----------
HF_TOKEN=hf_your_token_here
# Safety cap for model discovery cache. Set 0 for no cap.
HF_MAX_MODELS=5000

# ---------- Database ----------
POSTGRES_USER=modelserve
POSTGRES_PASSWORD=changeme
POSTGRES_DB=modelserve
DATABASE_URL=postgresql+asyncpg://modelserve:changeme@db:5432/modelserve

# ---------- Security ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string-min-32-chars

# ---------- vLLM ----------
VLLM_HOST=vllm
VLLM_PORT=8080
